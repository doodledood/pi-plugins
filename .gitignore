# Never commit live profile state; commit templates/examples only.
profiles/**/.pi/
profiles/**/git/
profiles/**/npm/
profiles/**/mcp.json
profiles/**/mcp-onboarding.json
profiles/**/mcp.json.pre-*.bak
profiles/**/auth.json
profiles/**/settings.json
profiles/**/models.json
!profiles/**/*.example.json
!profiles/**/*.template.json

