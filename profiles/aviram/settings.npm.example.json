    "npm:@doodledood/pi-goal-controller",
    "npm:@doodledood/pi-gpt-fast-toggle",
    "npm:@doodledood/pi-managed-chrome-devtools",
    "npm:@doodledood/pi-mcp-tool-loadout",
    "npm:@doodledood/pi-message-stash",
    "npm:@doodledood/pi-simple-statusline",
    "npm:@doodledood/pi-skill-argument-hints",
    "npm:@doodledood/pi-tool-activity-renderer",
    "npm:@doodledood/pi-theme-deep-focus-pi"
  ]
